# === paper-search-agent environment variables ===

# Elsevier (dev.elsevier.com)
# Required for Scopus discovery and Elsevier full-text via campus network
ELSEVIER_API_KEY=

# Springer Nature (dev.springernature.com)
# Used for Meta API v2 discovery and OpenAccess API
SPRINGER_API_KEY=

# Springer Nature Open Access API (may share key with SPRINGER_API_KEY)
SPRINGER_OA_API_KEY=

# NCBI / PubMed (optional — raises rate limit from 3 to 10 req/s)
NCBI_API_KEY=

# Unpaywall (api.unpaywall.org)
# A valid email address is required to use the Unpaywall API
UNPAYWALL_EMAIL=

# Zotero (optional — Web API mode)
ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=
ZOTERO_LIBRARY_TYPE=user  # "user" or "group"

# Semantic Scholar (optional, for higher rate limits)
SEMANTIC_SCHOLAR_API_KEY=

# Storage paths (defaults are relative to project root)
CACHE_DIR=./cache
CORPUS_DIR=./corpus
ARTIFACTS_DIR=./artifacts
